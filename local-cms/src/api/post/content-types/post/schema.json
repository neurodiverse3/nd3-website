{
  "kind": "collectionType",
  "collectionName": "posts",
  "info": {
    "singularName": "post",
    "pluralName": "posts",
    "displayName": "Post",
    "description": ""
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "pillar": {
      "type": "enumeration",
      "enum": [
        "glitchwork",
        "tiny-systems",
        "unmasked-life"
      ],
      "required": true
    },
    "brainState": {
      "type": "enumeration",
      "enum": [
        "burned-out",
        "hyperfocus",
        "masking",
        "spiraling",
        "on-a-roll"
      ],
      "required": true
    },
    "readTime": {
      "type": "string",
      "required": true
    },
    "excerpt": {
      "type": "text",
      "required": true
    },
    "body": {
      "type": "blocks",
      "required": true
    },
    "allowComments": {
      "type": "boolean",
      "default": true
    },
    "date": {
      "type": "date"
    },
    "coverImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "series": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::series.series",
      "inversedBy": "posts"
    }
  }
}