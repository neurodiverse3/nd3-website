# Public Strapi API base URL used by frontend/server code.
NEXT_PUBLIC_STRAPI_API_URL=http://127.0.0.1:1337

# Strapi API token for protected content/actions.
STRAPI_API_TOKEN=replace-with-strapi-read-token

# Resend API key for newsletter emails.
RESEND_API_KEY=replace-with-resend-api-key

# Polar.sh Configuration
POLAR_ACCESS_TOKEN=replace-with-polar-access-token
POLAR_PRODUCT_ID=replace-with-polar-generic-product-id
NEXT_PUBLIC_POLAR_ENV=sandbox
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Bing Webmaster Tools API Key
BING_WEBMASTER_API_KEY=replace-with-your-bing-api-key

# Composio API Key
COMPOSIO_API_KEY=replace-with-your-composio-api-key

# Allowed dev origins for server actions host header verification (comma-separated)
# ALLOWED_DEV_ORIGINS=lemon-fineness-remark.ngrok-free.dev,*.ngrok-free.dev,192.168.1.40

